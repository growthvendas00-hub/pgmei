# Configure estas variáveis no painel Vercel → Settings → Environment Variables
# Nunca commite o arquivo .env com valores reais

# Chaves da API Enki (obrigatórias)
ENKI_PUBLIC_KEY=pk_sua_chave_publica_aqui
ENKI_SECRET_KEY=sk_sua_chave_secreta_aqui

# Valor máximo por cobrança MEI em centavos. Padrão: 200000 = R$ 2.000
# ENKI_MAX_CENTAVOS=200000

# Nome do produto exibido na cobrança Enki
ENKI_PRODUCT_TITLE=Regularização MEI

# Opcional: webhook para notificações de pagamento
# ENKI_POSTBACK_URL=https://seu-projeto.vercel.app/api/webhook-enki

# Opcional: e-mail/telefone padrão do pagador quando não enviados pelo front
# ENKI_DEFAULT_EMAIL=seuemail@gmail.com
# ENKI_DEFAULT_PHONE=11999999999

# API de débitos MEI (continua usando o servidor remoto)
REMOTE_BASE=https://contribuinte2026.icu/v/teste-mei
